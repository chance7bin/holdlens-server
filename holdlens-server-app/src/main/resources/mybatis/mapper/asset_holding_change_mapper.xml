<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.echoamoy.holdlens.server.infrastructure.dao.IAssetHoldingChangeDao">

    <resultMap id="BaseResultMap" type="com.echoamoy.holdlens.server.infrastructure.dao.po.AssetHoldingChangePO">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="holding_id" property="holdingId"/>
        <result column="account_id" property="accountId"/>
        <result column="asset_id" property="assetId"/>
        <result column="change_type" property="changeType"/>
        <result column="before_amount" property="beforeAmount"/>
        <result column="after_amount" property="afterAmount"/>
        <result column="currency" property="currency"/>
        <result column="change_reason" property="changeReason"/>
        <result column="source_type" property="sourceType"/>
        <result column="source_ref_id" property="sourceRefId"/>
        <result column="operator_id" property="operatorId"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, holding_id, account_id, asset_id, change_type, before_amount, after_amount,
        currency, change_reason, source_type, source_ref_id, operator_id, create_time, update_time
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM asset_holding_change
        WHERE id = #{id}
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM asset_holding_change
        WHERE user_id = #{userId}
        ORDER BY id DESC
    </select>

    <select id="selectByHoldingId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM asset_holding_change
        WHERE holding_id = #{holdingId}
        ORDER BY id DESC
    </select>

    <select id="selectByAssetId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM asset_holding_change
        WHERE asset_id = #{assetId}
        ORDER BY id DESC
    </select>

    <select id="selectBySourceRefId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM asset_holding_change
        WHERE source_ref_id = #{sourceRefId}
        ORDER BY id DESC
    </select>

</mapper>
