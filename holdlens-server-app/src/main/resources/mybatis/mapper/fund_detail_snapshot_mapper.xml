<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.echoamoy.holdlens.server.infrastructure.dao.IFundDetailSnapshotDao">

    <resultMap id="BaseResultMap" type="com.echoamoy.holdlens.server.infrastructure.dao.po.FundDetailSnapshotPO">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="schema_version" property="schemaVersion"/>
        <result column="generated_at" property="generatedAt"/>
        <result column="snapshot_status" property="snapshotStatus"/>
        <result column="source_type" property="sourceType"/>
        <result column="source_ref_id" property="sourceRefId"/>
        <result column="data_sources_json" property="dataSourcesJson"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, schema_version, generated_at, snapshot_status, source_type,
        source_ref_id, data_sources_json, create_time, update_time
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM fund_detail_snapshot
        WHERE id = #{id}
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM fund_detail_snapshot
        WHERE user_id = #{userId}
        ORDER BY generated_at DESC, id DESC
    </select>

    <select id="selectBySourceRefId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM fund_detail_snapshot
        WHERE source_ref_id = #{sourceRefId}
        ORDER BY id DESC
    </select>

</mapper>
