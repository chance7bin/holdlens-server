<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.echoamoy.holdlens.server.infrastructure.dao.IProcessingLogDao">

    <resultMap id="BaseResultMap" type="com.echoamoy.holdlens.server.infrastructure.dao.po.ProcessingLogPO">
        <id column="id" property="id"/>
        <result column="source_ref_id" property="sourceRefId"/>
        <result column="module" property="module"/>
        <result column="event" property="event"/>
        <result column="message" property="message"/>
        <result column="severity" property="severity"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, source_ref_id, module, event, message, severity, create_time, update_time
    </sql>

    <insert id="insert" parameterType="com.echoamoy.holdlens.server.infrastructure.dao.po.ProcessingLogPO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO processing_log (
            source_ref_id, module, event, message, severity
        ) VALUES (
            #{sourceRefId}, #{module}, #{event}, #{message}, #{severity}
        )
    </insert>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM processing_log
        WHERE id = #{id}
    </select>

    <select id="selectBySourceRefId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM processing_log
        WHERE source_ref_id = #{sourceRefId}
        ORDER BY id DESC
    </select>

</mapper>
