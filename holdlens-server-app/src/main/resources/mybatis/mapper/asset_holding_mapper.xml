<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.echoamoy.holdlens.server.infrastructure.dao.IAssetHoldingDao">

    <resultMap id="BaseResultMap" type="com.echoamoy.holdlens.server.infrastructure.dao.po.AssetHoldingPO">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="account_id" property="accountId"/>
        <result column="asset_id" property="assetId"/>
        <result column="asset_category" property="assetCategory"/>
        <result column="holding_source" property="holdingSource"/>
        <result column="amount" property="amount"/>
        <result column="currency" property="currency"/>
        <result column="amount_display" property="amountDisplay"/>
        <result column="amount_missing_reason" property="amountMissingReason"/>
        <result column="missing_reasons_json" property="missingReasonsJson"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, account_id, asset_id, asset_category, holding_source, amount, currency,
        amount_display, amount_missing_reason, missing_reasons_json, status, create_time, update_time
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM asset_holding
        WHERE id = #{id}
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM asset_holding
        WHERE user_id = #{userId}
        ORDER BY id DESC
    </select>

    <select id="selectByUserIdAndAccountIdAndAssetId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM asset_holding
        WHERE user_id = #{userId}
          AND account_id = #{accountId}
          AND asset_id = #{assetId}
    </select>

    <select id="selectByAssetId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM asset_holding
        WHERE asset_id = #{assetId}
        ORDER BY id DESC
    </select>

</mapper>
