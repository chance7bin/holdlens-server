<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.echoamoy.holdlens.server.infrastructure.dao.IFundAssetAllocationDao">

    <resultMap id="BaseResultMap" type="com.echoamoy.holdlens.server.infrastructure.dao.po.FundAssetAllocationPO">
        <id column="id" property="id"/>
        <result column="fund_code" property="fundCode"/>
        <result column="asset_type" property="assetType"/>
        <result column="asset_type_name" property="assetTypeName"/>
        <result column="allocation_ratio" property="allocationRatio"/>
        <result column="display_order" property="displayOrder"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, fund_code, asset_type, asset_type_name, allocation_ratio, display_order, create_time, update_time
    </sql>

    <insert id="insertBatch">
        INSERT INTO fund_asset_allocation (
            fund_code, asset_type, asset_type_name, allocation_ratio, display_order
        ) VALUES
        <foreach collection="allocations" item="allocation" separator=",">
            (#{allocation.fundCode}, #{allocation.assetType}, #{allocation.assetTypeName},
             #{allocation.allocationRatio}, #{allocation.displayOrder})
        </foreach>
    </insert>

    <delete id="deleteByFundCode">
        DELETE FROM fund_asset_allocation WHERE fund_code = #{fundCode}
    </delete>

    <select id="selectByFundCodes" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM fund_asset_allocation
        WHERE fund_code IN
        <foreach collection="fundCodes" item="fundCode" open="(" separator="," close=")">
            #{fundCode}
        </foreach>
        ORDER BY fund_code ASC, display_order ASC, asset_type ASC, asset_type_name ASC
    </select>

</mapper>
