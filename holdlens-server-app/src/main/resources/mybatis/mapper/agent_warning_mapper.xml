<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.echoamoy.holdlens.server.infrastructure.dao.IAgentWarningDao">

    <resultMap id="BaseResultMap" type="com.echoamoy.holdlens.server.infrastructure.dao.po.AgentWarningPO">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="warning_type" property="warningType"/>
        <result column="source_type" property="sourceType"/>
        <result column="source_ref_id" property="sourceRefId"/>
        <result column="snapshot_id" property="snapshotId"/>
        <result column="fund_code" property="fundCode"/>
        <result column="code" property="code"/>
        <result column="message" property="message"/>
        <result column="source_section" property="sourceSection"/>
        <result column="row_number" property="rowNumber"/>
        <result column="severity" property="severity"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, warning_type, source_type, source_ref_id, snapshot_id, fund_code,
        code, message, source_section, row_number, severity, create_time, update_time
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM agent_warning
        WHERE id = #{id}
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM agent_warning
        WHERE user_id = #{userId}
        ORDER BY id DESC
    </select>

    <select id="selectBySnapshotId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM agent_warning
        WHERE snapshot_id = #{snapshotId}
        ORDER BY id DESC
    </select>

    <select id="selectByFundCode" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM agent_warning
        WHERE fund_code = #{fundCode}
        ORDER BY id DESC
    </select>

    <select id="selectBySourceRefId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM agent_warning
        WHERE source_ref_id = #{sourceRefId}
        ORDER BY id DESC
    </select>

</mapper>
